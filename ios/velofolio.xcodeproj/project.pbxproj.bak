				"${PODS_ROOT}/Target Support Files/Pods-velofolio/Pods-velofolio-frameworks-${CONFIGURATION}-output-files.xcfilelist",
			);
			runOnlyForDeploymentPostprocessing = 0;
			shellPath = /bin/sh;
			shellScript = "\"${PODS_ROOT}/Target Support Files/Pods-velofolio/Pods-velofolio-frameworks.sh\"\n";
